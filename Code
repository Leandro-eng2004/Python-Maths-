#Question 2-Runge-Kutta 4th Order Method for ODE
#===========================================================
import numpy as np
import matplotlib.pyplot as plt
# Simple RK4 solver
def rk4(p, y0):
"""
Solves ODE dy/dt + pty = cos(pi*t) using 4th order Runge-kutta method
Parameters
----------
 p:parameter in the ODE (p>0)
y0:intial condition
 Returns
-------
time array and solution array
"""
# Create time array with 500 point from 0 to 10
t = np.linspace(0, 10, 500)

y = np.zeros(500)
y[0] = y0 # Set initial condition
dt = t[1] - t[0] # Calculate time step
# RK4 iteration
for i in range(499):
# Calculate four coefficients
k1 = np.cos(np.pi*t[i]) - p*t[i]*y[i]
k2 = np.cos(np.pi*(t[i]+dt/2)) - p*(t[i]+dt/2)*(y[i] + k1*dt/2)
k3 = np.cos(np.pi*(t[i]+dt/2)) - p*(t[i]+dt/2)*(y[i] + k2*dt/2)
k4 = np.cos(np.pi*(t[i]+dt)) - p*(t[i]+dt)*(y[i] + k3*dt)
y[i+1] = y[i] + (k1 + 2*k2 + 2*k3 + k4) * dt / 6
return t, y
# Create plot
plt.figure(figsize=(10, 6))
# Plot solution for diffenrent p values with fixed intial condition
for p in [0.2, 0.5, 1.0]:
t, y = rk4(p, y0=1.0)
plt.plot(t, y, label=f'p = {p}, y_0 = 1.0')
# Different initial conditions with fixed p
for y0 in [0, 2]:
t, y = rk4(p=1.0, y0=y0)
plt.plot(t, y, '--', label=f'p = 1.0, y_0 = {y0}')
#Add plot information,like axis labels 
plt.xlabel('t')
plt.ylabel('y(t)')
plt.title('RK4 Solution: $dy/dt + pty = \cos(\pi t)$')
plt.legend()
plt.grid(True)
plt.show()
