# Question 1b-Euler Method for ODE Solution 
#=========================================================== 
import numpy as np
import matplotlib.pyplot as plt
def euler_method(y0, t0=0, tf=10, dt=0.01):
"""
Parameters

----------
y0:intial value 
t0:start time-default 0
tf:final time-default 10
dt:time step-default 0.01
 Returns
-------
t:array of time points
y:array of solution values
"""
# Create time array from t0 and tf with step st
t = np.arange(t0, tf + dt, dt)
# Start solution array with zeros
y = np.zeros_like(t)
y[0] = y0 # Set initial condition
#Euler method
for i in range(len(t)-1):
# Compute derivative at current time
dydt = y[i] * (1-y[i]) - 0.25 *np.sin(2 * np.pi *t[i])
# Update solution using Euler formula
y[i + 1] = y[i] + dt * dydt
return t, y
def euler_method_solution(y0):
"""
Plot solutions for mulriple initial conditions
Parameters
----------
y0:list of initial conditions to plot
"""
plt.figure(figsize=(8,6))
# Plot solution for each initial condition
for y0 in y0:
t, y = euler_method(y0)
plt.plot(t, y, label=f"y_0 = {y0}")
#Add plot information,like axis labels 
plt.title("Euler method solution")
plt.xlabel("t")
plt.ylabel("y(t)")
plt.legend()
plt.grid(True)
plt.show()
# Execute the function with sample initial conditions
euler_method_solution([0.5, 1, 3])
