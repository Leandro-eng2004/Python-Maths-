# Question 1a-3D Surface Plots of f(x,y) = e^(-ny) * sin(nx)
#============================================================
# Import libraries for numerical computation and plotting
import numpy as np
import matplotlib.pyplot as plt
def question_1a(n,x,y):
"""
Computes the function f(x,y) = e^(-n*y)*sin(n*x)
Parameters
----------
n : exponent and frequency parameter
x : coordinate array
y : coordinate array
 Returns: computed function values
"""
return np.exp(-n * y) * np.sin(n * x)
# Create coordinate grid for plotting
# x ranges from 0 to 10*pi with 100 points
# y ranges from -pi to pi with 100 points
x = np.linspace(0, 10*np.pi, 100)
y = np.linspace(-np.pi, np.pi, 100)
X, Y = np.meshgrid(x, y) # Creates a 2D grid from 1D arrays
# Create figure with 2x2 subplots
fig = plt.figure(figsize=(12, 8))
# Define different n values to visualize how the function changes
n_values = [-1, 0.5, 2, 4]
# Generate surface plots for each n value
for i, n in enumerate(n_values):
# Create 3D subplot
ax = fig.add_subplot(2, 2, i+1, projection='3d')
# Compute functions values over the grid
Z = question_1a(n, X, Y)
# Create surface plot with a colormap
ax.plot_surface(X, Y, Z, cmap='cividis')
# Add labels and title
ax.set_title(f'n = {n}')
ax.set_xlabel('X')
ax.set_ylabel('Y')
ax.set_zlabel('Z')
# Adjust layout and display plot
plt.tight_layout()
plt.show()
