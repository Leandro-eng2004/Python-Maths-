#Question 1c-Pi approximation with error analysis
#=========================================================== 
import numpy as np
import matplotlib.pyplot as plt
def pi_approx(tol):
"""
 Approximates pi using infinite series until error < tolerance
 Uses formula:pi~ sqrt(12) *((-3)^(-k)/(2k+1))
Parameters
----------
tol:tolerance for error
 Returns
-------
final M value and list of errors at each step

"""
# Initialize sum to zero-this will accumulate the series terms
s = 0
# Precompute constant for efficiency
sqrt12 = np.sqrt(12)
# Store errors at each iteration
errors = []
# Initialize loop counter M to track the current term num starting from 0
M = 0
# While loop condition:Continuing iterating while both conditions are TRUE:
# M < 100 to prevent infinte loos by limiting to 100 iterations
# abs(s - np.pi) >= tol:Continue while current error is >/= to tol
# The loop stops when either conditions become false 
while M < 100 and abs(s - np.pi) >= tol:
# Calculate the current term in infinte series
term = sqrt12 * ((-3) ** -M) / (2 * M + 1)
# Accumulates the partial sum of the series up to term M
s += term
# Calculation of the absolute eroor between the current approx & p 
error = abs(s - np.pi)
#Store the error value 
errors.append(error)
# Increment the term counter to move to the next term
M += 1
return M - 1, errors
# Execute pi approximation with specified tolerance
tol = 0.00001
final_M, errors = pi_approx(tol)
# Create semi-long plot of convergence
plt.figure(figsize=(8, 5))
plt.semilogy(range(len(errors)), errors, 'bo-')
plt.xlabel('M')
plt.ylabel('|s - pi|')
plt.title('Pi Approximation Convergence')
plt.legend()
plt.grid(True)
plt.show()
# Print converged results
print(f"Converged at M={final_M} with error={errors[-1]:.8f}")
