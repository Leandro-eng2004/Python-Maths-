# Question 1e-Binary matrix from random value
#===========================================================
def random_binary(n,m):
"""
Parameters
----------
n:Number of rows
 m:Number of columns
 Returns
-------
n xm binary matrix with values 0 or 1
"""
# Generate a n x m matrix with random values between 0 and 1
A = np.random.random((n,m))
# If element >=0.5,set to 1
# If element <0.5,set to 0
return np.where(A >= 0.5,1,0)
print("\nBinary matrix example (3x4):")
print(random_binary(3,4))
