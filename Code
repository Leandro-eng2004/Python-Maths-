# Question 1d-Custom n x m matrix with triangular pattern
#===========================================================
import numpy as np
import matplotlib.pyplot as plt
def upper_matrix(n):
"""
Parameters
----------

n:Size of the square matrix 
 Returns
-------
 A:n x n matrix with specified pattern
"""
# Initialize through each row of the matrix
A = np.zeros((n,n))
# Iterate through each column
for i in range(n):
if (i + 1) % 2 == 0:
A[i, i:] = i + 1
else:
# For odd rows,upper triangular part remains zero
A[i, i:] = 0
return A
# Example for Q1d testing with n=6
print("Matrix for n = 6:\n", upper_matrix(6))
